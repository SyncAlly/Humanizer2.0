# ── Supabase ───────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Your project URL (safe to expose in frontend too)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key — used by frontend for auth
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — backend ONLY, never expose to frontend
# Has full DB access, bypasses Row Level Security
SUPABASE_SERVICE_KEY=your-service-role-key-here


# ── Encryption ─────────────────────────────────────────────
# 32 random bytes encoded as hex — used to encrypt stored API keys
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_SECRET=your-64-char-hex-string-here


# ── Gemini (for eval/benchmark.py only) ────────────────────
# Users bring their own key via the app — this is only for running benchmarks
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your-gemini-api-key-here


# ── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local dev example: http://localhost:3000
# Production example: https://yourusername.github.io,https://humanizer.netlify.app
ALLOWED_ORIGINS=http://localhost:3000


# ── App ────────────────────────────────────────────────────
# Port the FastAPI server listens on (Railway sets this automatically)
PORT=8000

# Environment: development | production
ENVIRONMENT=development
